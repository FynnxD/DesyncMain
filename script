local function GetWallInfo(targetPart)
    if not targetPart then return true, 0 end

    local origin = Camera.CFrame.Position
    local direction = (targetPart.Position - origin)

    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LP.Character}

    local result = workspace:Raycast(origin, direction, params)
    if not result then
        return false, 0
    end

    local hitInstance = result.Instance
    local distance = (result.Position - origin).Magnitude

    local isWall = not hitInstance:IsDescendantOf(targetPart.Parent)
    return isWall, distance
end

local OriginalSizes = {}

local function SetHitbox(plr, size)
    if not plr.Character then return end
    local parts = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso"}
    for _, partName in ipairs(parts) do
        local part = plr.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            if not OriginalSizes[plr] then OriginalSizes[plr] = {} end
            if not OriginalSizes[plr][partName] then
                OriginalSizes[plr][partName] = part.Size
            end
            part.Size = OriginalSizes[plr][partName] * size
        end
    end
end

local function ResetHitbox(plr)
    if not plr.Character or not OriginalSizes[plr] then return end
    for partName, size in pairs(OriginalSizes[plr]) do
        local part = plr.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            part.Size = size
        end
    end
    OriginalSizes[plr] = nil
end

local function ApplyHitboxes(enabled, size)
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LP and IsValidTarget(plr) then
            if enabled then
                SetHitbox(plr, size)
            else
                ResetHitbox(plr)
            end
            plr.CharacterAdded:Connect(function()
                task.wait(0.2)
                if enabled then
                    SetHitbox(plr, size)
                else
                    ResetHitbox(plr)
                end
            end)
        end
    end
end

RunService.RenderStepped:Connect(function()
    Circle.Position = Center()
    Circle.Radius = Settings.FOV
    Circle.Visible = Settings.Aimbot

    if Settings.Aimbot and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local t = GetTarget()
        if t then
            Camera.CFrame = Camera.CFrame:Lerp(
                CFrame.new(Camera.CFrame.Position, t.Position),
                Settings.Smooth
            )
        end
    end

    if Settings.Triggerbot and TriggerCheck() then
        VIM:SendMouseButtonEvent(0,0,0,true,game,0)
        task.wait(0.01)
        VIM:SendMouseButtonEvent(0,0,0,false,game,0)
    end

    if Settings.Noclip and LP.Character then
        for _,p in ipairs(LP.Character:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CanCollide = false
            end
        end
    end

    ApplyMovement()

    local target = GetTarget()
    WBText.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2 + 40)
    if target then
        local wall, dist = GetWallInfo(target)
        if wall then
            WBText.Text = "WB: NO | Dist: "..math.floor(dist).." studs"
            WBText.Color = Color3.fromRGB(255,80,80)
        else
            WBText.Text = "WB: YES"
            WBText.Color = Color3.fromRGB(80,255,80)
        end
    else
        WBText.Text = "WB: N/A"
        WBText.Color = Color3.fromRGB(255,255,255)
    end
end)

